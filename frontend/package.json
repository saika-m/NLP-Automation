{
  "name": "tashi-frontend",
  "version": "2.0.0",
  "description": "Tashi - AI-Powered Automation Assistant (Web & Desktop)",
  "main": "electron-main.js",
  "scripts": {
    "start": "npm run start:desktop",
    "start:desktop": "electron .",
    "start:web": "npm run serve",
    "dev": "npm run dev:desktop",
    "dev:desktop": "NODE_ENV=development electron .",
    "dev:web": "npm run serve:dev",
    "serve": "npx http-server . -p 3000 -c-1 --cors",
    "serve:dev": "npx http-server . -p 3000 -c-1 --cors -o",
    "build": "npm run build:desktop",
    "build:desktop": "electron-builder",
    "build:web": "npm run build:web:prepare && npm run build:web:bundle",
    "build:web:prepare": "mkdir -p dist/web && cp -r *.html *.js *.css assets dist/web/ 2>/dev/null || true",
    "build:web:bundle": "echo 'Web build completed. Files are in dist/web/'",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --config jest.config.js",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.html",
    "lint:fix": "eslint . --ext .js,.html --fix"
  },
  "keywords": ["electron", "automation", "desktop", "commands", "ai", "productivity"],
  "author": "Tashi Team",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "playwright": "^1.40.0",
    "eslint": "^8.55.0",
    "eslint-plugin-electron": "^7.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "highlight.js": "^11.9.0",
    "marked": "^11.0.0",
    "prismjs": "^1.29.0"
  },
  "build": {
    "appId": "com.tashi.desktop",
    "productName": "Tashi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "web-app.js",
      "index.html",
      "styles.css",
      "assets/**/*",
      "components/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
