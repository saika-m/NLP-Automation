# Server Configuration
PORT=8080
GIN_MODE=release

# OpenAI Configuration
OPENAI_API_KEY=

# Database Configuration
DB_PATH=/app/data/tashi.db

# File Storage
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/outputs
TEMP_DIR=/app/data/temp

# Security
JWT_SECRET=your_jwt_secret_here_production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://tashi-frontend:3000

# Script Generation Settings
MAX_SCRIPT_SIZE=10485760
ALLOWED_EXTENSIONS=.ps1,.sh,.py,.exe,.bat
COMPILATION_TIMEOUT=300

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
